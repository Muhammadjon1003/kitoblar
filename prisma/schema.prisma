datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum StudentStatus {
  ACTIVE
  FROZEN
}

model Student {
  id                   Int           @id @default(autoincrement())
  name                 String
  totalLessonsAttended Int           @default(0)
  currentDebt          Float         @default(0.0)
  debtLimit            Float         @default(0.0)
  status               StudentStatus @default(ACTIVE)
  books                Book[]
  orders               Order[]
  financials           Financials?
}

enum BookStatus {
  IN_STOCK
  ORDERED
  ARRIVED
  DELIVERED
}

model Book {
  id          Int        @id @default(autoincrement())
  title       String
  teacherId   Int
  tgFileId    String     @unique
  status      BookStatus @default(IN_STOCK)
  studentId   Int?
  student     Student?   @relation(fields: [studentId], references: [id])
  orders      Order[]
  @@index([tgFileId])
}

enum LogisticsStatus {
  PENDING
  PROCESSING
  ARRIVED
}

model Order {
  id              Int             @id @default(autoincrement())
  studentId       Int
  bookId          Int
  logisticsStatus LogisticsStatus @default(PENDING)
  dateCreated     DateTime        @default(now())
  student         Student         @relation(fields: [studentId], references: [id])
  book            Book            @relation(fields: [bookId], references: [id])
}

model Financials {
  id               Int      @id @default(autoincrement())
  studentId        Int      @unique
  totalPrice       Float    @default(0.0)
  paidAmount       Float    @default(0.0)
  remainingBalance Float    @default(0.0)
  student          Student  @relation(fields: [studentId], references: [id])
}

model Session {
  userId String @id
  state  String
  data   String @default("{}")
}

model Category {
  id    Int            @id @default(autoincrement())
  name  String         @unique
  books TelegramBook[]

  @@map("categories")
}

model TelegramBook {
  id          Int      @id @default(autoincrement())
  tgFileId    String   @map("tg_file_id") @db.VarChar(255)
  tgMessageId Int      @map("tg_message_id")
  name        String   @db.VarChar(255)
  categoryId  Int      @map("category_id")
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("books")
}

// ─── ERP: Groups & Students (live management tables) ──────────────────────────

model ErpGroup {
  id                String       @id @default(cuid())
  groupName         String
  teacherName       String
  subjectCategory   String       @default("")
  startDate         String
  endDate           String
  orderIntervalDays Int          @default(30)
  createdAt         DateTime     @default(now())
  students          ErpStudent[]
  orders            ErpOrder[]

  @@map("erp_groups")
}

model ErpStudent {
  id          String     @id @default(cuid())
  fullName    String
  phoneNumber String     @default("")
  groupId     String
  group       ErpGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  joinedAt    DateTime   @default(now())
  orders      ErpOrder[]

  @@map("erp_students")
}

// ─── ERP: Orders (pipeline persistence) ──────────────────────────────────────

model ErpOrder {
  id         String     @id @default(cuid())
  studentId  String
  groupId    String
  bookId     String
  status     String     @default("CREATED")
  amountPaid Float      @default(0)
  bookCost   Float      @default(0)   // tan narxi — set by cashier at arrival
  sotuvNarxi Float      @default(0)   // sotuv narxi — locked from manager settings at order creation
  comment    String     @default("")
  updatedAt  String
  createdAt  DateTime   @default(now())

  student    ErpStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group      ErpGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("erp_orders")
}

// ─── ERP: Global Settings ──────────────────────────────────────────────

model ErpSettings {
  id         String   @id @default("global")
  sotuvNarxi Float    @default(0)   // manager-set selling price (so'm)
  updatedAt  DateTime @updatedAt

  @@map("erp_settings")
}

// ─── ERP: Users & Authentication ──────────────────────────────────────

model ErpUser {
  id        String   @id @default(cuid())
  fullName  String
  username  String   @unique
  password  String
  role      String   // TEACHER, CASHIER, LOGISTICS, MANAGER
  createdAt DateTime @default(now())

  @@map("erp_users")
}

